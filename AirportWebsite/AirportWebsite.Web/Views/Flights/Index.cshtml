@using AirportWebsite.Web.ViewModels
@model FlightSearchViewModel
@{
    ViewData["Title"] = "Поиск рейсов";
}

<div class="row mb-4">
    <div class="col-md-8 mx-auto">
        <div class="card p-4 shadow-sm">
            <h2 class="text-accent mb-3">Поиск авиабилетов</h2>
            <form asp-action="Index" asp-controller="Flights" method="get" class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Origin" class="form-label">Откуда</label>
                    <input asp-for="Origin" class="form-control" placeholder="Например: Moscow" />
                    <span asp-validation-for="Origin" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Destination" class="form-label">Куда</label>
                    <input asp-for="Destination" class="form-control" placeholder="Например: Saint Petersburg" />
                    <span asp-validation-for="Destination" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DepartureDate" class="form-label">Дата вылета</label>
                    <input asp-for="DepartureDate" type="date" class="form-control" />
                    <span asp-validation-for="DepartureDate" class="text-danger"></span>
                </div>
                <div class="col-12 text-end">
                    <button type="submit" class="btn btn-primary">Найти рейсы</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.Flights != null && Model.Flights.Any())
{
    <div class="row">
        @foreach (var flight in Model.Flights)
        {
            <div class="col-md-6 mb-3">
                <div class="card flight-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title text-accent fw-bold">@flight.FlightNumber</h5>
                            <span class="badge bg-success">@flight.Status</span>
                        </div>
                        <div class="row text-center mb-3">
                            <div class="col-4">
                                <h3>@flight.DepartureTimeFormatted</h3>
                                <small class="text-muted">@flight.Origin</small>
                            </div>
                            <div class="col-4 d-flex align-items-center justify-content-center">
                                <span class="text-muted">➝</span>
                            </div>
                            <div class="col-4">
                                <h3>@flight.ArrivalTimeFormatted</h3>
                                <small class="text-muted">@flight.Destination</small>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div>
                                <small class="text-muted d-block">@flight.DateFormatted</small>
                                <small class="text-muted">Мест: @flight.AvailableSeats</small>
                            </div>
                            <div class="text-end">
                                <div class="h5 mb-0">@flight.Price.ToString("N0") ₽</div>
                                @if (flight.AvailableSeats > 0)
                                {
                                    <a asp-controller="Bookings" asp-action="Create" asp-route-id="@flight.Id" class="btn btn-sm btn-secondary mt-1">Купить</a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary disabled" disabled>Нет мест</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model.Origin != null || Model.Destination != null)
{
    <div class="alert alert-info text-center">Рейсы не найдены. Попробуйте изменить параметры поиска.</div>
}
